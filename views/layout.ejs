<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Reflect</title>
  <link rel="stylesheet" href="/styles.css" />

  <script>
    window.currentUser = "<%= currentUser || '' %>";
    window.userInfo = <%- JSON.stringify(userInfo || []) %>;
  </script>

  <script src="/js/comment.js"></script>
  <script src="/js/profile.js"></script>
  <script src="/js/writePost.js"></script>
</head>

<body>
  <% const user = (userInfo || []).find(u => u.uid === currentUser); %>
  <div class="page-shell">
    <header class="navbar">
      <div class="greeting">
        ⊹ ࣪ ˖ Hello there,
        <span class="user-name"><%= user?.name || "User" %></span>
      </div>

      <a href="/" class="logo">REFLECT</a>

      <nav class="nav-links">
        <a href="/profile" class="nav-link <%= currentPage === 'profile' ? 'active' : '' %>">
          Your Profile
        </a>

        <a href="/" class="nav-link <%= currentPage === 'newsfeed' ? 'active' : '' %>">
          Newsfeed
        </a>

        <form action="/logout" method="POST" class="logout-form">
          <button type="submit" class="nav-link logout-btn">
            Logout
          </button>
        </form>
      </nav>
    </header>

    <main class="main-panel">
      <%- body %>
    </main>

    <button class="write-post-btn" onclick="openWritePost()">+</button>
  </div>

  <%- include("components/writePostModal", { promptStarters }) %>
  <script src="/js/prompt.js" defer></script>

  <template id="comment-template">
    <%- include("components/comment", {
      comment: { text: "", createdAt: "" },
      user: { name: "", avatar: "" }
    }) %>
  </template>
</body>
</html>