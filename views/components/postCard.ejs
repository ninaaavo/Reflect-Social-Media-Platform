<div class="post-card">
  <h2 class="post-title"><%= postTitle %></h2>
  <p class="post-author">Posted by <%= postAuthor %></p>
  <p class="post-content"><%= postText %></p>

  <!-- Comment Icon -->
  <button class="comment-toggle" onclick="toggleComments(this)">
    💬
  </button>

  <!-- Comment Section -->
  <div class="comment-section hidden">
    
    <div class="comments-list">
      <% if (comments && comments.length > 0) { %>
        <% comments.forEach(comment => { %>
          <div class="comment">
            <p><%= comment %></p>
          </div>
        <% }) %>
      <% } else { %>
        <p class="no-comments">No comments yet</p>
      <% } %>
    </div>

    <!-- Input -->
    <div class="comment-input-area">
      <input
        class="comment-input"
        value="<%= userPromptAnswer %>"
        placeholder="Write a comment..."
      />
      <button class="send-comment-btn" onclick="sendComment(this)">
        Send
      </button>
    </div>

  </div>
</div>