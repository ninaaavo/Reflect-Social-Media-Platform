<div class="write-post-overlay hidden" id="writePostOverlay" onclick="closeWritePost(event)">
  <div class="write-post-modal" onclick="event.stopPropagation()">
    <button class="close-write-post" onclick="closeWritePost()">×</button>

    <h2 class="write-post-title">Write a new post</h2>

    <form action="/post" method="POST" enctype="multipart/form-data" class="write-post-form" onsubmit="handlePostSubmit(event)">
      <label class="prompt-label">
        <div class="label-with-info">
          Prompt question
          <span class="info-icon">i
            <span class="tooltip-text">
              This is the question people must answer before seeing your post. 
              Make it thoughtful and reflective to spark meaningful responses.
            </span>
          </span>
        </div>

        <div class="prompt-builder">
          <select name="questionStarter" required class="question-starter">
            <option value="">Select a prompt style...</option>
            <% promptStarters.forEach(starter => { %>
              <option value="<%= starter %>"><%= starter + " ..."%></option>
            <% }) %>
          </select>
        </div>

        <div>
          <input
            type="text"
            name="questionBody"
            placeholder="finish the sentence..."
            required
            class="prompt-text"
          />
        </div>
      </label>

      <!-- hidden final question -->
      <input type="hidden" name="question" id="finalQuestion" />

      <label>
        Post title
        <input
          name="postTitle"
          type="text"
          placeholder="Give your post a title..."
          required
        />
      </label>

      <label>
        Your post
        <textarea
          name="postText"
          placeholder="Write what you want to share..."
          required
        ></textarea>
      </label>

      <label class="image-upload-label">
        Add image (optional)
        <input
          type="file"
          name="image"
          accept="image/*"
          onchange="previewImage(event)"
        />
      </label>

      <div class="image-preview-container">
        <img id="imagePreview" class="image-preview hidden" />
      </div>

      <button type="submit" class="submit-post-btn">
        Post
      </button>
    </form>
  </div>
</div>